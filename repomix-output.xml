            <p className="text-lg font-semibold text-gray-800">
              {currentCount} <span className="text-sm font-normal text-gray-500">/ {subscription.plan_type === 'premium' ? dict.video.unlimited : `${limit}${dict.video.videosUnit}`}</span>
            </p>
          </div>
        </div>
      </div>
